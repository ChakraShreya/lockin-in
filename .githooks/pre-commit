#!/bin/sh
# Blocks direct commits on main — PRs only (see CONTRIBUTING.md).
branch=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$branch" = "main" ]; then
  echo "✗ Direct commits to main are not allowed — PRs only (CONTRIBUTING.md)."
  echo "  Create a branch first:  git checkout -b <type>/<short-desc>"
  echo "  Emergency bypass (rare): git commit --no-verify"
  exit 1
fi
exit 0
